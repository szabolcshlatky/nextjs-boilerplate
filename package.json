{
  "name": "react-next-guide",
  "version": "1.0.0",
  "description": "Legacy frontend boilerplate",
  "keywords": [
    "nextjs",
    "tailwindcss",
    "react",
    "postcss",
    "tsx",
    "jsx"
  ],
  "author": "Coding Sable",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "react-next-guide"
  },
  "main": "index.ts",
  "type": "module",
  "engines": {
    "pnpm": ">=6.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "jest": "jest"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pnpm run lint && pnpm run jest"
    }
  },
  "dependencies": {
    "next": "14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/eslint": "^8.56.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "6.17.0",
    "@typescript-eslint/parser": "6.17.0",
    "autoprefixer": "^10.4.16",
    "cssnano": "6.0.2",
    "eslint": "^8.56.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-next": "14.0.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-prettier": "5.1.2",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-react-refresh": "0.4.5",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "lodash": "4.17.21",
    "postcss": "^8.4.32",
    "prettier": "3.1.1",
    "sass": "1.69.7",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "uuid": "9.0.1"
  }
}